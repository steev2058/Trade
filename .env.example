# Runtime
APP_ENV=production
LOG_LEVEL=INFO
TIMEZONE=UTC
MODE=paper

# Security
MASTER_KEY_BASE64=
ENABLE_ENCRYPTED_SECRETS=true

# MT5
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk limits
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_TRADES_PER_DAY=20
MAX_CONCURRENT_POSITIONS=5
MIN_BALANCE_PROTECTION=0
COOLDOWN_AFTER_LOSSES=0

# Trading defaults
DEFAULT_SYMBOL=EURUSD

# Strategy toggles
ENABLE_SMC_ICT=true
ENABLE_SCALPER=true
ENABLE_NEWS=true
ENABLE_ADAPTIVE_WEIGHTING=true
ENABLE_LONDON_NY_SESSION=true
ENABLE_SR_FVG=true

# Auto execution (phase 4)
AUTO_TRADING_ENABLED=false
AUTO_DEFAULT_SYMBOL=XAUUSD.m
AUTO_DEFAULT_LOT=0.01
RISK_MODE=normal
STRICT_POINT_VALUE_VALIDATION=true
AUTO_COOLDOWN_SECONDS=120
REPORT_INTERVAL_SECONDS=3600
WATCH_SYMBOLS=XAUUSD.m,BRENT.m
DAILY_DRAWDOWN_LIMIT_PCT=6.0
DAILY_PROFIT_TARGET_PCT=3.0
ICT_KILLZONES_ENABLED=true
ICT_LONDON_KILLZONE_UTC=07:00-10:00
ICT_NEWYORK_KILLZONE_UTC=12:00-15:00

# Polling
TICK_INTERVAL_SECONDS=3
HEARTBEAT_SECONDS=60
