# Runtime
APP_ENV=production
LOG_LEVEL=INFO
TIMEZONE=UTC
MODE=paper

# Security
MASTER_KEY_BASE64=
ENABLE_ENCRYPTED_SECRETS=true

# MT5
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk limits
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_TRADES_PER_DAY=20
MAX_CONCURRENT_POSITIONS=5

# Strategy toggles
ENABLE_SCALPING=true
ENABLE_SWING=true
ENABLE_NEWS=true

# Polling
TICK_INTERVAL_SECONDS=3
HEARTBEAT_SECONDS=60
