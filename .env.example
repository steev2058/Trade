# Runtime
APP_ENV=production
LOG_LEVEL=INFO
TIMEZONE=UTC
MODE=paper

# Security
MASTER_KEY_BASE64=
ENABLE_ENCRYPTED_SECRETS=true

# MT5
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk limits
MAX_RISK_PER_TRADE=0.02
RISK_PERCENT_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_TRADES_PER_DAY=20
MAX_CONCURRENT_POSITIONS=5
MIN_BALANCE_PROTECTION=0
COOLDOWN_AFTER_LOSSES=0
MIN_ALLOWED_LOT=0.01
MAX_ALLOWED_LOT=1.0
MIN_LOT_SIZE=0.01
MAX_LOT_SIZE=1.0
USD_STOP_PER_0_01_LOT=5.0
RR_RATIO=3.0

# Trading defaults
DEFAULT_SYMBOL=EURUSD

# Strategy toggles
ENABLE_SMC_ICT=true
ENABLE_SCALPER=true
ENABLE_NEWS=true
ENABLE_ADAPTIVE_WEIGHTING=true
ENABLE_LONDON_NY_SESSION=true
ENABLE_SR_FVG=true

# Auto execution (phase 4)
AUTO_TRADING_ENABLED=false
AUTO_DEFAULT_SYMBOL=XAUUSD.m
AUTO_DEFAULT_LOT=0.01
RISK_MODE=balanced
STRICT_POINT_VALUE_VALIDATION=true
REQUIRE_PROTECTED_EXECUTION=true
PAPER_VALUATION_POLICY=warn
AUTO_COOLDOWN_SECONDS=120
REPORT_INTERVAL_SECONDS=3600
WATCH_SYMBOLS=XAUUSD.m,BRENT.m
DAILY_DRAWDOWN_LIMIT_PCT=6.0
DAILY_PROFIT_TARGET_PCT=3.0
ICT_KILLZONES_ENABLED=true
ICT_LONDON_KILLZONE_UTC=07:00-10:00
ICT_NEWYORK_KILLZONE_UTC=12:00-15:00
ASIA_SESSION_UTC=01:00-06:00
ASIA_NEWS_BLOCK_ENABLED=true
ASIA_NEWS_HIGH_IMPACT=false

# External analysis agents (analysis-only)
DEXTER_ENABLED=false
DEXTER_BASE_URL=http://dexter-service:8081
DEXTER_TIMEOUT_SECONDS=45
TRADING_AGENTS_ENABLED=false
TRADING_AGENTS_BASE_URL=http://tradingagents-service:8082
TRADING_AGENTS_TIMEOUT_SECONDS=60
CONSENSUS_MIN_CONFIDENCE=0.75

# Polling
TICK_INTERVAL_SECONDS=3
HEARTBEAT_SECONDS=60
